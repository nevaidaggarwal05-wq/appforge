# ═══════════════════════════════════════════════════════════════
# AppForge Admin Panel — env vars
# Copy to .env.local and fill in before running `npm run dev`
# ═══════════════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Firebase Admin SDK — ONE shared project for FCM delivery
FIREBASE_PROJECT_ID=app-template-66952
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@app-template-66952.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"

# Public URLs
NEXT_PUBLIC_APP_URL=https://admin.yourdomain.com
