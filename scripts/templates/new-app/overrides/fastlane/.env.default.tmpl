# {{DISPLAY_NAME}} — fastlane environment defaults.
# Auto-loaded by fastlane when running from ~/Desktop/builds/{{SLUG}}/.
# Paths use ~ expansion so this file stays portable.

# ─── Android (Google Play) ────────────────────────────────────────
ANDROID_PACKAGE_NAME={{PACKAGE}}
PLAY_SERVICE_ACCOUNT_JSON=~/Desktop/{{SLUG}}-play-service-account.json

# ─── iOS (App Store Connect) ──────────────────────────────────────
# Single ASC API key works for ALL apps under one Apple Developer team.
IOS_BUNDLE_ID={{PACKAGE}}
ASC_KEY_PATH=~/Desktop/asc-api-key.p8
# Fill these once Apple Developer enrollment is active:
# ASC_KEY_ID=ABCDE12345
# ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

IOS_CHANGELOG=Bug fixes and improvements.
